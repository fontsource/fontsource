{
	"$schema": "https://biomejs.dev/schemas/2.2.2/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/coverage",
			"!**/__snapshots__",
			"!**/dist",
			"!**/build",
			"!**/.source",
			"!**/.wrangler",
			"!**/worker-configuration.d.ts",
			"!**/.react-router"
		]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"css": {
		"formatter": {
			"enabled": false
		},
		"linter": {
			"enabled": false
		},
		"parser": {
			"cssModules": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"enabled": true,
		"domains": {
			"react": "all"
		},
		"rules": {
			"recommended": true,
			"correctness": {
				"useUniqueElementIds": "off",
				"noUnknownMediaFeatureName": "off",
				"noUnknownProperty": "off"
			},
			"style": {
				"useComponentExportOnlyModules": {
					"options": {
						"allowExportNames": [
							"action",
							"clientAction",
							"clientLoader",
							"clientMiddleware",
							"handle",
							"headers",
							"links",
							"loader",
							"meta",
							"middleware",
							"shouldRevalidate"
						]
					}
				}
			},
			"suspicious": {
				"noUnknownAtRules": "off"
			}
		}
	}
}
