{
	"include": [
		".react-router/types/**/*",
		".source/**/*.ts",
		"../packages/core/src/**/*.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/.server/**/*.ts",
		"**/.server/**/*.tsx",
		"**/.client/**/*.ts",
		"**/.client/**/*.tsx",
		"worker-configuration.d.ts",
		"vite.config.ts"
	],
	"compilerOptions": {
		"checkJs": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"composite": true,
		"noUncheckedSideEffectImports": true,
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["vite/client"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"rootDirs": [".", "./.react-router/types"],
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"paths": {
			"@fontsource-utils/core": ["../packages/core/src/index.ts"],
			"collections/*": ["./.source/*"],
			"@/docs/*": ["./docs/*"],
			"@/*": ["./app/*"]
		}
	}
}
