{
	"name": "fontsource-worker-api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun --filter '@fontsource-utils/core' build && vite build",
		"check": "biome check --write .",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy",
		"deploy:staging": "CLOUDFLARE_ENV=staging bun run deploy",
		"dev": "bun --filter '@fontsource-utils/core' build && vite dev",
		"preview": "bun run build && vite preview",
		"coverage": "bun --filter '@fontsource-utils/core' build && vitest run --coverage",
		"test": "bun --filter '@fontsource-utils/core' build && vitest run",
		"typecheck": "bun --filter '@fontsource-utils/core' build && bun x tsc -p worker/tsconfig.json --noEmit && bun x tsc -p tests/tsconfig.json --noEmit && bun x tsc -p container/tsconfig.json --noEmit",
		"format": "biome format --write .",
		"ci:format": "biome format .",
		"lint": "biome lint --write .",
		"ci:lint": "biome lint ."
	},
	"dependencies": {
		"@cloudflare/containers": "^0.2.2",
		"@fontsource-utils/core": "workspace:*",
		"aws4fetch": "^1.0.20",
		"chanfana": "^2.5.0",
		"compare-versions": "^6.1.1",
		"fflate": "^0.8.2",
		"hono": "^4.12.10",
		"limit-concur": "^4.0.0",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.31.2",
		"@cloudflare/vitest-pool-workers": "^0.14.1",
		"@types/node": "^25.5.2",
		"bun-types": "^1.3.11",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.81.1"
	}
}
